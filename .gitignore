# Dependencies
node_modules/
.venv/
venv/
env/

# Build
dist/
build/
*.egg-info/
__pycache__/
target/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment + credentials — never commit
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
.secrets
*.secret*
credentials*
secrets/
*.local

# SSH private keys (no-extension forms — won't be caught by *.key)
id_rsa
id_ed25519
id_ecdsa
id_dsa
*-key
!*-key.pub

# Claude Code session credentials
.claude/.credentials.json
.credentials.json

# Bulk-upload-of-home-dir leakage. The Windows uploader sometimes
# absorbs files from C:\Users\... or C:\Windows\... into the repo,
# encoding the colon as a Unicode private-use char. Block both forms.
C:Users*
C:Windows*

# Documents that commonly contain live credentials
VOXCLAW.md
SECRETS.md
CREDENTIALS.md
PRIVATE.md
CREDS.md

# Session scratch — never commit
scratch/

# Windows reserved device names (cause git add failures)
nul
con
prn
aux
com1
com2
com3
com4
com5
com6
com7
com8
com9
lpt1
lpt2
lpt3
lpt4
lpt5
lpt6
lpt7
lpt8
lpt9
